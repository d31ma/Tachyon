{
  "name": "@d31ma/tachyon",
  "version": "26.28.05",
  "description": "A polyglot, file-system-routed full-stack framework for Bun",
  "author": "Chidelma",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "init": "bun src/cli/index.js init",
    "serve": "bun src/cli/index.js serve",
    "bundle": "bun src/cli/index.js bundle",
    "preview": "bun src/cli/index.js preview --watch",
    "bundle:watch": "bun src/cli/index.js bundle --watch",
    "start": "bun run serve",
    "build:exe": "mkdir -p dist-bin && bun build --compile ./src/cli/index.js --outfile ./dist-bin/ty",
    "typecheck": "bun scripts/typecheck.js",
    "test": "bun --env-file=tests/.env.test test ./tests --max-concurrency=1 --timeout 120000",
    "test:coverage": "bun --env-file=tests/.env.test test ./tests --coverage --max-concurrency=1 --timeout 120000",
    "stress:tac": "bun tests/stress/tac-dom-stress.js",
    "bench:build": "bun scripts/bench/run.mjs"
  },
  "keywords": [
    "tachyon",
    "bun",
    "framework",
    "api",
    "polyglot",
    "file-system-routing",
    "javascript",
    "jsdoc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d31ma/Tachyon.git"
  },
  "homepage": "https://tachyon.del.ma",
  "bugs": {
    "url": "https://github.com/d31ma/Tachyon/issues"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/bun": "^1.3.4",
    "@types/deno": "^2.0.0",
    "@types/node": "^20.4.2",
    "happy-dom": "^20.8.9",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3"
  }
}
