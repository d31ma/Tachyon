{
    "name": "@delma/tachyon",
  "version": "1.11.1",
    "description": "A polyglot, file-system-routed full-stack framework for Bun",
    "author": "Chidelma",
    "license": "MIT",
    "type": "module",
    "main": "./src/server/route-handler.ts",
    "types": "./src/server/route-handler.ts",
    "exports": {
        ".": "./src/server/route-handler.ts",
        "./server": "./src/server/process-executor.ts",
        "./compiler": "./src/compiler/template-compiler.ts"
    },
    "bin": {
        "tach.init": "./bin/tach.init.js",
        "tach.serve": "./bin/tach.serve.js",
        "tach.bundle": "./bin/tach.bundle.js",
        "tach.preview": "./bin/tach.preview.js"
    },
    "scripts": {
        "init": "bun src/cli/init.ts",
        "serve": "bun src/cli/serve.ts",
        "bundle": "bun src/cli/bundle.ts",
        "preview": "bun src/cli/preview.ts --watch",
        "bundle:watch": "bun src/cli/bundle.ts --watch",
        "start": "bun run serve",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "test:coverage": "bun test --coverage"
    },
    "files": [
        "bin/",
        "examples/middleware.upstash.ts",
        "src/",
        "README.md",
        ".env.example"
    ],
    "keywords": [
        "tachyon",
        "bun",
        "framework",
        "api",
        "polyglot",
        "file-system-routing",
        "typescript"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/d31ma/Tachyon.git"
    },
    "homepage": "https://tachyon.del.ma",
    "bugs": {
        "url": "https://github.com/d31ma/Tachyon/issues"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "^20.8.9",
        "@types/bun": "^1.3.4",
        "@types/deno": "^2.0.0",
        "@types/node": "^20.4.2",
        "happy-dom": "^20.8.9",
        "playwright": "^1.59.1",
        "typescript": "^6.0.2"
    }
}

