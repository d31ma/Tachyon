<script>
  document.title = "Home";

  let count = 0;
  let showInfo = false;
  let newTodo = "";
  let todos = [
    { text: "Learn Yon framework", completed: false },
    { text: "Build an application", completed: false },
  ];

  let componentTitle = "Component Test";
  let componentDesc = "This tests custom components in Yon";

  function addTodo() {
    if (newTodo) {
      todos = [...todos, { text: newTodo, completed: false }];
      newTodo = "";
    }
  }

  function toggleTodo(index) {
    todos = todos.map((todo, i) =>
      i === index ? { ...todo, completed: !todo.completed } : todo
    );
  }

  function removeTodo(index) {
    todos = todos.filter((_, i) => i !== index);
  }
</script>

<h1>Yon Framework Test</h1>

<ty-clicker :clicks="count" />

<vc-card title="Counter Example" elevation="1">
  <div slot="content">
    <vc-btn @click="count++">Increment</vc-btn>
    <p>Count: <span>{count}</span></p>
    <vc-btn @click="count--">Decrement</vc-btn>
  </div>
</vc-card>

<h2>Todo List</h2>
<vc-text-field label="Add new todo" :value="newTodo"></vc-text-field>
<vc-btn @click="addTodo()">Add</vc-btn>

<vc-list>
  <ty-loop :for="let i = 0; i < todos.length; i++">
    <vc-list-item>
      <vc-checkbox
        :label="todos[i].text"
        @change="toggleTodo(i)"
        :checked="todos[i].completed"
      ></vc-checkbox>
      <vc-btn @click="removeTodo(i)" color="secondary" size="small"> Remove </vc-btn>
    </vc-list-item>
  </ty-loop>
</vc-list>

<ty-logic :if="showInfo">
  <vc-card title="Framework Info" elevation="1">
    <div slot="content">
      <p>
        This is testing the conditional rendering feature of the Yon framework.
      </p>
    </div>
    <div slot="actions">
      <vc-btn @click="showInfo = false">Hide Info</vc-btn>
    </div>
  </vc-card>
</ty-logic>
<ty-logic :else>
  <vc-card elevation="1">
    <div slot="actions">
      <vc-btn @click="showInfo = true">Show Info</vc-btn>
    </div>
  </vc-card>
</ty-logic>

<ty-clicker :clicks="count" />