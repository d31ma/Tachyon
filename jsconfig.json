{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["bun-types", "@types/node"],
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": true,
    "allowImportingTsExtensions": true,
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": false,
    "paths": {
      "@/*": ["./examples/server/*"]
    }
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.js",
    "tests/**/*.js",
    "examples/**/*.d.ts",
    "examples/**/*.js",
    "examples/**/*.ts",
    "scripts/**/*.js"
  ],
  "exclude": ["node_modules", "node_modules*", "dist", "bin", "**/*.as.ts", "examples/dist", "examples/dist-debug", "examples/node_modules", "examples/node_modules*"]
}
