{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["@types/bun", "@types/node"],
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": true,
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.js",
    "tests/**/*.js",
    "examples/**/*.d.ts",
    "examples/**/*.js",
    "examples/**/*.ts",
    "scripts/**/*.js"
  ],
  "exclude": ["node_modules", "dist", "bin", "examples/dist", "examples/dist-debug", "examples/node_modules"]
}
