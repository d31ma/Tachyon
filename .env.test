# Tachyon test environment variables
YON_PORT=8000
YON_TIMEOUT=70
YON_LOG_LEVEL=info
YON_LOG_FORMAT=pretty
YON_TRUST_PROXY=
# Frontend module output: esm (default) or global for window.Yon registry modules
TAC_FORMAT=esm
# Explicit allowlist of browser-visible env vars. Never put secrets here.
TAC_PUBLIC_ENV=
# Maximum request body bytes buffered before returning HTTP 413 (default: 1048576)
YON_MAX_BODY_BYTES=1048576
# Maximum ms a handler process may run before it is killed (default: 30000)
YON_HANDLER_TIMEOUT_MS=30000
YON_OTEL_ENABLED=false
YON_OTEL_ROOT=
YON_OTEL_SERVICE_NAME=@d31ma/tachyon
YON_OTEL_SERVICE_VERSION=
# Opt in only if your telemetry policy allows storing client IP addresses
YON_OTEL_CAPTURE_IP=false
FYLO_ROOT=db/collections
FYLO_SCHEMA_DIR=db/schemas
FYLO_INDEX_BACKEND=s3-prefix
FYLO_S3_ACCESS_KEY_ID=test
FYLO_S3_SECRET_ACCESS_KEY=test
FYLO_S3_SESSION_TOKEN=
FYLO_S3_REGION=us-east-1
FYLO_S3_ENDPOINT=http://localhost:4566
# Required when schemas declare $encrypted fields
FYLO_ENCRYPTION_KEY=
FYLO_CIPHER_SALT=
YON_DATA_BROWSER_ENABLED=false
YON_DATA_BROWSER_READONLY=true
YON_DATA_BROWSER_REVEAL=false
YON_RATE_LIMIT_MAX=
YON_RATE_LIMIT_WINDOW_MS=
YON_DEV=
# Uncomment to enforce OPTIONS schema validation during manual test runs.
# YON_VALIDATE=true
YON_HOSTNAME=127.0.0.1
# Require this token for /hmr when serving on a non-loopback host
YON_HMR_TOKEN=
YON_HMR_MAX_CLIENTS=20
YON_ALLOW_HEADERS=*
# Restrict to explicit origins in production — never use * with credentials enabled
YON_ALLOW_ORIGINS=https://yourdomain.com
YON_ALLOW_CREDENTIALS=
YON_ALLOW_EXPOSE_HEADERS=
YON_ALLOW_MAX_AGE=3600
YON_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# Generate strong credentials at deployment time — never commit real credentials
YON_BASIC_AUTH=
# Override default CSP if your app loads scripts/styles from external origins
YON_CONTENT_SECURITY_POLICY=default-src 'self'
# Opt into HSTS only when serving HTTPS directly or behind a trusted HTTPS proxy
YON_ENABLE_HSTS=false
YON_HSTS_VALUE=max-age=31536000; includeSubDomains
