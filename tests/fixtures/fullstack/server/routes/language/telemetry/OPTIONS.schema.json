{
  "GET": {
    "request": {
      "query": {
        "limit?": "^(?:[1-9]|[1-4][0-9]|50)$"
      }
    },
    "200": {
      "summary": {
        "enabled": "^(?:true|false)$",
        "collection": "^[0-9A-Za-z_-]+$",
        "spanCount": "^[0-9]+$",
        "requestCount": "^[0-9]+$",
        "errorCount": "^[0-9]+$"
      },
      "recent": [
        {
          "traceId": "^[\\s\\S]{0,128}$",
          "spanId": "^[\\s\\S]{0,128}$",
          "parentSpanId?": "^[\\s\\S]*$",
          "kind": "^[\\s\\S]{0,64}$",
          "name": "^[\\s\\S]{0,256}$",
          "requestId?": "^[\\s\\S]*$",
          "route?": "^[\\s\\S]*$",
          "method?": "^[\\s\\S]*$",
          "statusCode?": "^[\\s\\S]*$",
          "traceState?": "^[\\s\\S]*$",
          "startTimeUnixNano": "^\\d*$",
          "endTimeUnixNano": "^\\d*$",
          "durationMs": "^\\d+(\\.\\d+)?$"
        }
      ]
    },
    "500": {
      "detail": "^[\\s\\S]+$"
    }
  }
}
