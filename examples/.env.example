# Server
YON_PORT=8080
YON_HOST=127.0.0.1
YON_HOSTNAME=127.0.0.1
YON_DEV=true
YON_LOG_LEVEL=info
YON_LOG_FORMAT=pretty
YON_TRUST_PROXY=
YON_MAX_BODY_BYTES=1048576
YON_HANDLER_TIMEOUT_MS=30000
YON_MAX_PARAM_LENGTH=1000

# Tac
TAC_FORMAT=esm
TAC_PUBLIC_ENV=
YON_PAGES_PATH=browser/pages
YON_COMPONENTS_PATH=browser/components
YON_ASSETS_PATH=browser/shared/assets
YON_SHARED_SCRIPTS_PATH=browser/shared/scripts
YON_SHARED_STYLES_PATH=browser/shared/styles
YON_SHARED_DATA_PATH=browser/shared/data
YON_ROUTES_PATH=server/routes
YON_MIDDLEWARE_PATH=./middleware

# Rate limiting
YON_RATE_LIMIT_MAX=
YON_RATE_LIMIT_WINDOW_MS=

# HMR
YON_HMR_TOKEN=
YON_HMR_MAX_CLIENTS=20

# Security
YON_ALLOW_HEADERS=Content-Type,Authorization
YON_ALLOW_ORIGINS=
YON_ALLOW_CREDENTIALS=false
YON_ALLOW_EXPOSE_HEADERS=
YON_ALLOW_MAX_AGE=3600
YON_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
YON_BASIC_AUTH=
YON_BASIC_AUTH_HASH=
YON_VALIDATE=true
YON_CONTENT_SECURITY_POLICY=default-src 'self'
YON_ENABLE_HSTS=false
YON_HSTS_VALUE=max-age=31536000; includeSubDomains

# FYLO document store
FYLO_ROOT=db
FYLO_SCHEMA=db/schemas
FYLO_INDEX_BACKEND=local-fs
YON_DATA_BROWSER_ENABLED=true
YON_DATA_BROWSER_READONLY=false
YON_DATA_BROWSER_REVEAL=false

# FYLO field-level encryption
# Required when any schema declares `$encrypted` fields. Must be at least 32 chars.
FYLO_ENCRYPTION_KEY=local-dev-encryption-key-change-me-32
FYLO_CIPHER_SALT=tachyon-example-salt

# OpenTelemetry
YON_OTEL_ENABLED=false
YON_OTEL_ROOT=
YON_OTEL_SERVICE_NAME=tachyon-showcase
YON_OTEL_SERVICE_VERSION=2.0.0
YON_OTEL_CAPTURE_IP=false
