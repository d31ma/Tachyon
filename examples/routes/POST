#!/usr/bin/env -S java --source 25 --class-path /Users/iyor/Library/CloudStorage/Dropbox/myProjects/TACHYON/lib/gson-2.3.jar

import java.io.*;
import com.google.gson.JsonParser;

void main() {

    System.out.println("Executing Java...");

    BufferedReader br = new BufferedReader(new InputStreamReader(System.in));

    try {

        var ctx = new JsonParser().parse(br.readLine()).getAsJsonObject();

        System.out.println(ctx.get("context"));

        System.out.print("{\"message\":\"Hello from Java!\"}");

    } catch (Exception e) {
        System.err.print("Error processing JSON: " + e.getMessage());
    }
}