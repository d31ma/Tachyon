  </logic>

  <div class="stats">
    <div class="stat-card">
      <div class="stat-label">Completed</div>
      <div class="stat-value">{doneCount()}</div>
      <sl-progress-bar :value="percent()"></sl-progress-bar>
    </div>
    <div class="stat-card">
      <div class="stat-label">Pending</div>
      <div class="stat-value">{pendingCount()}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total</div>
      <div class="stat-value">{tasks.length}</div>
    </div>
  </div>

  <div class="task-panel">
    <sl-card>
      <div class="task-header">
        <h2>Tasks <sl-badge variant="neutral" pill>{lastUpdated}</sl-badge></h2>
        <sl-button-group>
          <sl-button size="small" @click="filter = `all`">All</sl-button>
          <sl-button size="small" @click="filter = `pending`">Pending</sl-button>
          <sl-button size="small" @click="filter = `done`">Done</sl-button>
        </sl-button-group>
      </div>

      <div class="add-row">
        <sl-input placeholder="What needs to be done?" size="small" :value="newTask"></sl-input>
        <sl-button variant="primary" size="small" @click="addTask()">
          <sl-icon slot="prefix" name="plus-lg"></sl-icon>
          Add
        </sl-button>
      </div>

      <logic :if="filtered().length > 0">
        <ul class="task-list">
          <loop :for="let i = 0; i < filtered().length; i++">
            <li class="task-item">
              <sl-checkbox :checked="filtered()[i].done" @click="toggle(tasks.indexOf(filtered()[i]))"></sl-checkbox>
              <span class="task-text">
                <logic :if="filtered()[i].done">
                  <s>{filtered()[i].text}</s>
                  <sl-badge variant="success" pill>done</sl-badge>
                </logic>
                <logic :if="!filtered()[i].done">
                  {filtered()[i].text}
                </logic>
              </span>
              <sl-icon-button name="x-lg" label="Remove" @click="remove(tasks.indexOf(filtered()[i]))"></sl-icon-button>
            </li>
          </loop>
        </ul>
      </logic>
      <logic :if="filtered().length === 0">
        <div class="empty-state">
          <sl-icon name="inbox" style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></sl-icon>
          No tasks match this filter.
        </div>
      </logic>
    </sl-card>
  </div>

  <div class="component-section">
    <h2>Custom Yon Components</h2>
    <div class="component-grid">
      <clicker_ :clicks="doneCount()" />
      <clicker_ lazy :clicks="pendingCount()" />
    </div>
  </div>

