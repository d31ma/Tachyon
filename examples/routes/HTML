<script>
  document.title = "Home — Tachyon Playground";

  const { default: dayjs } = await import('/modules/dayjs.js');

  let greeting = "Welcome to Tachyon";
  let lastUpdated = dayjs().format('MMM D, YYYY h:mm A');

  let tasks = [
    { text: "Define API routes as plain executables", done: true },
    { text: "Build reactive pages with Yon templates", done: true },
    { text: "Mix in Shoelace web components", done: false },
    { text: "Deploy to production", done: false },
  ];

  let newTask = "";
  let filter = "all";
  let showAbout = false;

  function addTask() {
    if (newTask.trim()) {
      tasks = [...tasks, { text: newTask.trim(), done: false }];
      newTask = "";
      lastUpdated = dayjs().format('MMM D, YYYY h:mm A');
    }
  }

  function toggle(index) {
    tasks = tasks.map((t, i) =>
      i === index ? { ...t, done: !t.done } : t
    );
  }

  function remove(index) {
    tasks = tasks.filter((_, i) => i !== index);
  }

  function filtered() {
    if (filter === "done") return tasks.filter(t => t.done);
    if (filter === "pending") return tasks.filter(t => !t.done);
    return tasks;
  }

  function doneCount() {
    return tasks.filter(t => t.done).length;
  }

  function pendingCount() {
    return tasks.filter(t => !t.done).length;
  }

  function percent() {
    return tasks.length ? Math.round((doneCount() / tasks.length) * 100) : 0;
  }
</script>

