{
  "GET": {
    "200": {
      "method": "^GET$",
      "result": "^[0-9]+$"
    }
  },
  "POST": {
    "request": {
      "body": "^[\\s\\S]*$"
    },
    "200": {
      "method": "^POST$",
      "result": "^[\\s\\S]+$"
    }
  },
  "PUT": {
    "200": {
      "method": "^PUT$",
      "result": "^[0-9]+$"
    }
  },
  "PATCH": {
    "request": {
      "body": {
        "language": "^[A-Za-z+#]+$",
        "message": "^[\\s\\S]+$"
      }
    },
    "200": {
      "method": "^PATCH$",
      "result": {
        "language": "^[A-Za-z+#]+$",
        "message": "^[\\s\\S]+$"
      }
    }
  },
  "DELETE": {
    "200": {
      "method": "^DELETE$",
      "result": "^(true|false)$"
    }
  }
}
