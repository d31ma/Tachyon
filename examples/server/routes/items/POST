#!/usr/bin/env bun

const dataPath = `${process.cwd()}/server/data/items.json`

async function ensureItems() {
    const file = Bun.file(dataPath)
    if (!await file.exists()) {
        await Bun.write(file, '[]')
    }
}

async function readItems() {
    await ensureItems()
    return await Bun.file(dataPath).json()
}

/**
 * @param {unknown[]} items
 * @returns {Promise<void>}
 */
async function writeItems(items) {
    await ensureItems()
    await Bun.write(dataPath, JSON.stringify(items, null, 2))
}

const { body } = await Bun.stdin.json()

if (!body?.name || !String(body.name).trim()) {
    Bun.stdout.write(JSON.stringify({ detail: 'name is required' }))
} else {
    const item = {
        id: crypto.randomUUID(),
        name: String(body.name).trim(),
        source: String(body.source || 'api'),
        createdAt: new Date().toISOString(),
    }

    await writeItems([item, ...await readItems()])
    Bun.stdout.write(JSON.stringify(item))
}
