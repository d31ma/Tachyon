{
  "GET": {
    "request": {
      "query": {
        "limit?": "^(?:[1-9]|[1-4][0-9]|50)$"
      }
    },
    "200": {
      "summary": {
        "enabled": "^(?:true|false)$",
        "collection": "^[0-9A-Za-z_-]+$",
        "spanCount": "^[0-9]+$",
        "requestCount": "^[0-9]+$",
        "errorCount": "^[0-9]+$"
      },
      "recent": [
        {
          "traceId": "^[0-9a-f]{32}$",
          "spanId": "^[0-9a-f]{16}$",
          "parentSpanId?": "^(?:[0-9a-f]{16})?$",
          "kind": "^(?:server|internal|client|producer|consumer|unspecified)$",
          "name": "^.{1,200}$",
          "requestId?": "^.{1,200}$",
          "route?": "^/.*$",
          "method?": "^(?:GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS)$",
          "statusCode?": "^[0-9]{3}$",
          "traceState": "^[\\s\\S]*$",
          "startTimeUnixNano": "^[0-9]+$",
          "endTimeUnixNano": "^[0-9]+$",
          "durationMs": "^[0-9]+(?:\\.[0-9]+)?$"
        }
      ]
    },
    "500": {
      "detail": "^[\\s\\S]+$"
    }
  }
}
