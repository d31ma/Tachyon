# Dev server (bun run serve) — the site is frontend-only: client/ bundles and
# serves on one port. Tac Workers mimic the backend and the in-browser FYLO
# client (OPFS) mimics the database.
YON_PORT=8080
YON_HOST=127.0.0.1
YON_HOSTNAME=127.0.0.1
YON_DEV=true
YON_LOG_LEVEL=info
YON_LOG_FORMAT=pretty

# Tac compiler / bundle
TAC_FORMAT=esm
TAC_PUBLIC_ENV=PUBLIC_PACKAGE_NAME
PUBLIC_PACKAGE_NAME=@d31ma/tachyon

# Security headers — Wasm workers need 'wasm-unsafe-eval'; the live panel
# streams Wikimedia edits over SSE, so allow that origin in connect-src.
YON_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self'; connect-src 'self' https://stream.wikimedia.org; img-src 'self' data:
YON_ENABLE_HSTS=false
