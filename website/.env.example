# Dev server (bun run serve) — the site is frontend-only: client/ bundles and
# serves on one port. Tac companions and the in-browser FYLO client (OPFS)
# demonstrate the runtime without a server or database directory.
YON_PORT=8080
YON_HOST=127.0.0.1
YON_HOSTNAME=127.0.0.1
YON_DEV=true
YON_LOG_LEVEL=info
YON_LOG_FORMAT=pretty

# Tac compiler / bundle
TAC_FORMAT=esm
TAC_PUBLIC_ENV=PUBLIC_PACKAGE_NAME
PUBLIC_PACKAGE_NAME=@d31ma/tachyon

# Optional device APIs for the portable companion demo. The browser fails
# closed when a capability is absent, so this is safe to omit in a web-only app.
TAC_NATIVE_CAPABILITIES=app.info

# Security headers for the runtime and live Wikimedia SSE panel.
YON_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self'; worker-src 'self'; connect-src 'self' https://stream.wikimedia.org; img-src 'self' data:
YON_ENABLE_HSTS=false
