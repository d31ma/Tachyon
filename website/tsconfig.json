{
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": false,
    "types": ["@types/bun", "@types/node"]
  },
  "include": [
    "tachyon-env.d.ts",
    "client/**/*.js",
    "client/**/*.ts",
    "tests/**/*.js"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "client/shared/assets/duvay/**/*.js"
  ]
}
